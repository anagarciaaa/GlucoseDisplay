<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:context=".MainActivity">

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ConneXX"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintHorizontal_bias="0.498"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.051" />

        <Button
            android:id="@+id/startSessionButton"
            android:layout_width="125dp"
            android:layout_height="51dp"
            android:layout_marginTop="12dp"
            android:background="@color/colorPrimary"
            android:bottomLeftRadius="10dp"
            android:bottomRightRadius="10dp"
            android:padding="10dp"
            android:text="Start Session"
            android:textColor="#FFFFFF"
            android:topLeftRadius="10dp"
            android:topRightRadius="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/title" />

        <Button
            android:id="@+id/joinSessionButton"
            android:layout_width="120dp"
            android:layout_height="51dp"
            android:layout_marginTop="8dp"
            android:background="@color/colorPrimary"
            android:bottomLeftRadius="10dp"
            android:bottomRightRadius="10dp"
            android:padding="10dp"
            android:text="Join Session"
            android:textColor="#FFFFFF"
            android:topLeftRadius="10dp"
            android:topRightRadius="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/startSessionButton" />

        <Button
            android:id="@+id/editProfileButton"
            android:layout_width="120dp"
            android:layout_height="51dp"
            android:layout_marginTop="8dp"
            android:background="@color/colorPrimary"
            android:bottomLeftRadius="10dp"
            android:bottomRightRadius="10dp"
            android:padding="10dp"
            android:text="Edit Profile"
            android:textColor="#FFFFFF"
            android:topLeftRadius="10dp"
            android:topRightRadius="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/joinSessionButton" />

        <Button
            android:id="@+id/pairSensorButton"
            android:layout_width="120dp"
            android:layout_height="51dp"
            android:layout_marginTop="8dp"
            android:background="@color/colorPrimary"
            android:bottomLeftRadius="10dp"
            android:bottomRightRadius="10dp"
            android:padding="10dp"
            android:text="Pair Sensor"
            android:textColor="#FFFFFF"
            android:topLeftRadius="10dp"
            android:topRightRadius="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/editProfileButton" />

        <Button
            android:id="@+id/testCgmButton"
            android:layout_width="120dp"
            android:layout_height="51dp"
            android:layout_marginTop="8dp"
            android:background="#AA0000"
            android:bottomLeftRadius="10dp"
            android:bottomRightRadius="10dp"
            android:padding="10dp"
            android:text="Test CGM"
            android:textColor="#FFFFFF"
            android:topLeftRadius="10dp"
            android:topRightRadius="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/pairSensorButton" />

        <TextView
            android:id="@+id/cgm_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text=""
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/testCgmButton" />

        <FrameLayout
            android:id="@+id/cgm_preview_container"
            android:layout_width="200dp"
            android:layout_height="100dp"
            android:layout_marginTop="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cgm_status" />

        <TextView
            android:id="@+id/user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="76dp"
            android:text="Hello!"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cgm_preview_container" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>